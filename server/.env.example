# ============================================
# PROTRADER BACKEND — ENVIRONMENT TEMPLATE
# ============================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

APP_NAME=ProTrader
APP_ENV=development
DEBUG=true
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Public URL for algo-bot webhooks (no trailing slash). TradingView CANNOT use localhost or http://...:8000
# (error: "Only port 80 is allowed for HTTP"). Use HTTPS tunnel or production:
#   ngrok http 8000   →  PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.app
PUBLIC_API_BASE_URL=

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=protrader

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

INFOWAY_API_KEY=
INFOWAY_REST_BASE=https://data.infoway.io
INFOWAY_WS_BASE=wss://data.infoway.io/ws

PLATFORM_BTC_ADDRESS=
PLATFORM_ETH_ADDRESS=
PLATFORM_USDT_ADDRESS=

SUPER_ADMIN_EMAIL=admin@protrader.com
SUPER_ADMIN_PASSWORD=
